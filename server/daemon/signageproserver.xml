<service>
	<id>signageproserver.exe</id>
	<name>SignagePro Server</name>
	<description>오설록 SignagePro 원격 관리 서버</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>C:\WorkSpace\signagepro\server\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\WorkSpace\signagepro\server\index.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>SignagePro Server wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>DESKTOP-0ITUG5U</domain>
		<user>LocalSystem</user>
		<password></password>
		<allowservicelogon>true</allowservicelogon>
	</serviceaccount>
	<workingdirectory>C:\WorkSpace\signagepro\server</workingdirectory>
</service>