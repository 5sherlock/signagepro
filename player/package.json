{
  "name": "signage-player",
  "version": "1.0.0",
  "description": "SignagePro Remote Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.signagepro.player",
    "productName": "SignagePro Player",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "SignagePro",
  "license": "ISC",
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "node-machine-id": "^1.1.12",
    "socket.io-client": "^4.7.4"
  }
}
