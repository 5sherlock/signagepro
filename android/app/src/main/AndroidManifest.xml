<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 네트워크 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- 부팅 자동 실행 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 화면 꺼짐 방지 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".PlayerApp"
        android:allowBackup="false"
        android:icon="@android:drawable/ic_menu_slideshow"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SignageProPlayer"
        android:usesCleartextTraffic="true"
        tools:targetApi="22">

        <!-- 부팅 후 자동 실행 진입점 (LAUNCHER만 등록 — HOME은 추후 정식 키오스크 단계에서 추가) -->
        <activity
            android:name=".BootActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 첫 부팅 시 deviceId/서버 URL 입력 -->
        <activity
            android:name=".SetupActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- 풀스크린 키오스크 (실제 재생 화면) -->
        <activity
            android:name=".KioskActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.SignageProPlayer.Fullscreen" />

        <!-- 부팅 완료 리시버 -->
        <receiver
            android:name=".boot.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
